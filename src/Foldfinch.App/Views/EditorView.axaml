<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Foldfinch.App.ViewModels"
             x:Class="Foldfinch.App.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <Panel Background="{StaticResource CanvasBgBrush}">
        <!-- Empty state: shown until a document is opened. -->
        <StackPanel IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8" MaxWidth="420">
            <TextBlock Text="No PDF open" FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="{StaticResource TitleBrush}" />
            <TextBlock Text="Open a PDF to remove, reorder, or rotate its pages — or add several to combine them into one."
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <!-- Document summary (M2). The visual page grid replaces this in M3. -->
        <StackPanel IsVisible="{Binding !IsEmpty}" Margin="28" Spacing="14">
            <TextBlock Text="{Binding DocumentName}" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TitleBrush}" />
            <TextBlock Text="Page thumbnails arrive next. Sources in this document:"
                       Foreground="{StaticResource MutedBrush}" />
            <ItemsControl ItemsSource="{Binding SourceSummaries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <TextBlock Text="{Binding}" Foreground="{StaticResource FgBrush}" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Panel>
</UserControl>
