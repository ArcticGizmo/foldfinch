<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Foldfinch.App.ViewModels"
             x:Class="Foldfinch.App.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <UserControl.Styles>
        <!-- Page tile frame; turns into an accent-bordered card when selected. -->
        <Style Selector="Border.page">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.page.selected">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Border.selband">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.selband.selected">
            <Setter Property="Background" Value="#1A2563EB" />
        </Style>
    </UserControl.Styles>

    <Panel Background="{StaticResource CanvasBgBrush}">
        <!-- Empty state: shown until a document is opened. -->
        <StackPanel IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8" MaxWidth="420">
            <TextBlock Text="No PDF open" FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="{StaticResource TitleBrush}" />
            <TextBlock Text="Open a PDF to remove, reorder, or rotate its pages — or add several to combine them into one."
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <!-- Page grid. Drag a page to reorder; click / Ctrl+click / Shift+click to select. -->
        <ScrollViewer IsVisible="{Binding !IsEmpty}" Padding="20" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Pages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:PageThumbnailViewModel">
                        <Border Classes="selband" Classes.selected="{Binding IsSelected}" CornerRadius="8" Padding="8" Margin="4">
                            <StackPanel Width="200" Spacing="6">
                                <!-- Source chip: only shown when the document combines multiple files. -->
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center"
                                            IsVisible="{Binding ShowSource}">
                                    <Border Width="9" Height="9" CornerRadius="5" VerticalAlignment="Center"
                                            Background="{Binding SourceColor}" />
                                    <TextBlock Text="{Binding SourceLabel}" FontSize="11" MaxWidth="165"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>

                                <!-- Fixed-size stage keeps the grid aligned; the white page card inside is sized
                                     to the thumbnail's own aspect ratio, so rotated (landscape) pages look right. -->
                                <Panel Height="264">
                                    <!-- Loading placeholder (portrait card). -->
                                    <Border IsVisible="{Binding IsLoading}" Width="186" Height="248"
                                            Background="#FFFFFF" CornerRadius="3" BoxShadow="0 1 4 0 #22000000"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="…" FontSize="20" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                                    </Border>
                                    <!-- Loaded page: the card hugs the image (aspect-correct in both orientations). -->
                                    <Border Classes="page" Classes.selected="{Binding IsSelected}"
                                            IsVisible="{Binding !IsLoading}"
                                            Background="#FFFFFF" CornerRadius="3" ClipToBounds="True"
                                            BoxShadow="0 1 4 0 #22000000"
                                            MaxWidth="196" MaxHeight="256"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{Binding Image}" Stretch="Uniform"
                                               MaxWidth="196" MaxHeight="256" />
                                    </Border>
                                </Panel>

                                <TextBlock Text="{Binding PageNumber}" FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Drag-reorder drop indicator (an insertion line), positioned in code-behind. -->
        <Canvas x:Name="DropOverlay" IsHitTestVisible="False" IsVisible="{Binding !IsEmpty}">
            <Border x:Name="DropLine" Width="3" CornerRadius="1.5" IsVisible="False"
                    Background="{StaticResource AccentBrush}" BoxShadow="0 0 4 0 #552563EB" />
        </Canvas>
    </Panel>
</UserControl>
