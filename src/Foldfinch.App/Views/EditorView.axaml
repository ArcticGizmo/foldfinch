<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Foldfinch.App.ViewModels"
             x:Class="Foldfinch.App.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <UserControl.Styles>
        <!-- Page tile frame; turns into an accent-bordered card when selected. -->
        <Style Selector="Border.page">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.page.selected">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Border.selband">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.selband.selected">
            <Setter Property="Background" Value="#1A2563EB" />
        </Style>
    </UserControl.Styles>

    <Panel Background="{StaticResource CanvasBgBrush}">
        <!-- Empty state: shown until a document is opened. -->
        <StackPanel IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8" MaxWidth="420">
            <TextBlock Text="No PDF open" FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="{StaticResource TitleBrush}" />
            <TextBlock Text="Open a PDF to remove, reorder, or rotate its pages — or add several to combine them into one."
                       TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <!-- Page grid. Drag a page to reorder; click / Ctrl+click / Shift+click to select. -->
        <ScrollViewer IsVisible="{Binding !IsEmpty}" Padding="20" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Pages}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:PageThumbnailViewModel">
                        <Border Classes="selband" Classes.selected="{Binding IsSelected}" CornerRadius="8" Padding="8" Margin="4">
                            <StackPanel Width="200" Spacing="6">
                                <!-- Source chip: only shown when the document combines multiple files. -->
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center"
                                            IsVisible="{Binding ShowSource}">
                                    <Border Width="9" Height="9" CornerRadius="5" VerticalAlignment="Center"
                                            Background="{Binding SourceColor}" />
                                    <TextBlock Text="{Binding SourceLabel}" FontSize="11" MaxWidth="165"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>

                                <!-- The page. Fixed height keeps the grid tidy regardless of page aspect. -->
                                <Border Classes="page" Classes.selected="{Binding IsSelected}"
                                        Background="#FFFFFF" CornerRadius="3" Height="260"
                                        HorizontalAlignment="Center" ClipToBounds="True"
                                        BoxShadow="0 1 4 0 #22000000">
                                    <Panel>
                                        <TextBlock Text="…" IsVisible="{Binding IsLoading}" FontSize="20"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <Image Source="{Binding Image}" Stretch="Uniform" Margin="6" />
                                    </Panel>
                                </Border>
                                <TextBlock Text="{Binding PageNumber}" FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Panel>
</UserControl>
