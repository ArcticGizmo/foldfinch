<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Foldfinch.App.ViewModels"
        x:Class="Foldfinch.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1180" Height="800"
        MinWidth="720" MinHeight="480"
        Background="{StaticResource FormBgBrush}"
        Title="Foldfinch">

    <Window.Styles>
        <!-- Toolbar buttons -->
        <Style Selector="Button.tool">
            <Setter Property="Background" Value="{StaticResource ButtonBgBrush}" />
            <Setter Property="Foreground" Value="{StaticResource FgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.tool:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Foldfinch" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TitleBrush}" VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <Button Classes="tool" Content="Open" IsEnabled="False" />
                    <Button Classes="tool" Content="Add PDF" IsEnabled="False" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Classes="tool" Content="Save As" IsEnabled="False" />
                    <Button Classes="tool primary" Content="Save" IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Editor surface -->
        <ContentControl Content="{Binding Editor}" />
    </DockPanel>
</Window>
